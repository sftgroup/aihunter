# AIHunter 环境变量配置模板
# 复制此文件为 .env 并填入真实值后启动：
#   cp deploy/.env.example deploy/.env

# ============================================
# Gateway 鉴权 Token（必填，生产环境务必修改）
# ============================================
AUTH_TOKEN=your_secure_auth_token_here

# ============================================
# OKX API 凭证（V6 OnchainOS，必填）
# ============================================
OKX_API_KEY=your_okx_api_key
OKX_SECRET_KEY=your_okx_secret_key
OKX_PASSPHRASE=your_okx_passphrase

# ============================================
# 数据库连接（必填）
# ============================================
DATABASE_URL=postgresql://aihunter:aihunter2025@postgres:5432/aihunter

# ============================================
# Redis 连接（必填）
# ============================================
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# ============================================
# AI 供应商 API Key（可选）
# ============================================
DEEPSEEK_API_KEY=

# ============================================
# RPC 节点（可选，默认使用 publicnode）
# ============================================
# RPC_URL_ETH=https://ethereum-rpc.publicnode.com
# RPC_URL_BSC=https://bsc-rpc.publicnode.com
# RPC_URL_BASE=https://base-rpc.publicnode.com
# RPC_URL_SOL=https://api.mainnet-beta.solana.com
