# AIHunter 安全配置 — 复制为 .env 并填入实际值
# ⚠️  禁止将 .env 文件提交到版本控制

# ---- 认证 ----
AUTH_TOKEN=changeme-use-a-strong-random-string

# ---- 数据库 ----
POSTGRES_USER=aihunter
POSTGRES_PASSWORD=changeme-use-a-strong-random-password
POSTGRES_DB=aihunter

# ---- Redis ----
REDIS_PASSWORD=changeme-use-a-strong-random-password

# ---- AI 供应商 ----
DEEPSEEK_API_KEY=

# ---- RPC 节点 ----
RPC_URL_ETH=https://ethereum-rpc.publicnode.com
RPC_URL_BSC=https://bsc-rpc.publicnode.com
RPC_URL_BASE=https://base-rpc.publicnode.com
RPC_URL_SOL=https://api.mainnet-beta.solana.com

# ---- OKX ----
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
